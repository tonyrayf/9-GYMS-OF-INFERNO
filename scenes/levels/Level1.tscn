[node name="Dialog2" parent="." unique_id=1540387580 instance=ExtResource("6_lha2r")]
full_text = [[1, "О, новенький! А ты чего такой злой?"], [0, "Вы убили моего брата и ограбили нашу семейную качалку."], [1, "Что? Убили? Я видел, что его душу разделили на части и поместили\\nв магические блины."], [1, "От них и питается наша качалка. "], [0, "Тогда я должен вернуть блины, чтобы его душа упокоилась с миром."], [1, "Хорошо, я тебя остановить не смогу. Блины вон там."]]

