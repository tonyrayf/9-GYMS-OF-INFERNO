[node name="Dialog" parent="." unique_id=963855277 instance=ExtResource("1_m6fch")]
visible = true
full_text = [[0, "Сдавайся! Ты проиграл. У меня с собой все девять блинов."], [0, "И я уже вернул брату душу."], [0, "да"], [1, "Как это возможно? Я же был сильнее тебя! Я был быстрее тебя! Я был лучше тебя!"], [0, "Может ты и превосходишь меня грубой силой, но ты точно не лучше. "], [0, "Ты думал, что сильнее тебя нет никого, поэтому не стремился к совершенству."], [0, "А я смог увидеть собственные слабости. "], [0, "Преодолеть их и стать лучше. Быстрее. Сильнее, чем когда-либо."], [0, "В этом и есть сила."]]
autostart = true

